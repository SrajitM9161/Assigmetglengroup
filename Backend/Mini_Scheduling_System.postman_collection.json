{
  "info": {
    "name": "Mini Employee Scheduling System",
    "description": "Postman requests for the Flask assignment backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:3000"},
    {"key": "assignmentId", "value": ""}
  ],
  "item": [
    {"name": "Get employees", "request": {"method": "GET", "url": "{{baseUrl}}/api/employees"}},
    {"name": "Get jobs", "request": {"method": "GET", "url": "{{baseUrl}}/api/jobs"}},
    {"name": "Get schedule", "request": {"method": "GET", "url": "{{baseUrl}}/api/schedule"}},
    {
      "name": "Assign available employee",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "X-Role", "value": "scheduler"}],
        "body": {"mode": "raw", "raw": "{\n  \"employeeId\": \"emp-001\",\n  \"jobId\": \"job-001\"\n}"},
        "url": "{{baseUrl}}/api/assign"
      },
      "event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('assignmentId', pm.response.json().data.id); }"]}}]
    },
    {
      "name": "Reject unavailable employee",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"employeeId\": \"emp-004\",\n  \"jobId\": \"job-002\"\n}"},
        "url": "{{baseUrl}}/api/assign"
      }
    },
    {
      "name": "Reject overlapping job",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {"mode": "raw", "raw": "{\n  \"employeeId\": \"emp-001\",\n  \"jobId\": \"job-004\"\n}"},
        "url": "{{baseUrl}}/api/assign"
      }
    },
    {
      "name": "Delete last assignment",
      "request": {"method": "DELETE", "header": [{"key": "X-Role", "value": "scheduler"}], "url": "{{baseUrl}}/api/assign/{{assignmentId}}"}
    }
  ]
}
